{
  "expo": {
    "name": "WorkNest",
    "slug": "worknest-hrms",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B4FE8"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lakshithatech.worknest",
      "infoPlist": {
        "NSCameraUsageDescription": "WorkNest needs camera to capture your attendance selfie.",
        "NSLocationWhenInUseUsageDescription": "WorkNest needs location to verify you are at the office.",
        "NSFaceIDUsageDescription": "Use Face ID for quick login to WorkNest."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B4FE8"
      },
      "package": "com.lakshithatech.worknest",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.USE_BIOMETRIC",
        "android.permission.VIBRATE"
      ]
    },
    "plugins": [
      "expo-camera",
      "expo-location",
      "expo-secure-store",
      "expo-local-authentication",
      ["expo-notifications", { "icon": "./assets/icon.png", "color": "#1B4FE8" }]
    ]
  }
}
